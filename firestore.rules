rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Players collection — one document per signed-in user (keyed by their uid).
    match /players/{userId} {

      // Anyone signed in can read the leaderboard.
      allow read: if request.auth != null;

      // A user may only create / update their OWN document.
      // They may NOT set their own points from the client — points are 0 on
      // create, and only an admin / server (Cloud Function or console) can
      // award points later. This stops students from cheating their score.
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.points == 0;

      // Allow the user to update their own document if EITHER:
      //   - their `points` value stays exactly the same (e.g. nickname edit), OR
      //   - their `points` value increases by exactly 1 (a correct quiz answer).
      //
      // POC compromise: this means a determined cheater could still spam the
      // +1 path from the JS console to farm points. The proper hardening is a
      // Cloud Function that awards points only after server-side answer
      // verification — that's the next anti-cheat step.
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && (
                      request.resource.data.points == resource.data.points
                      || request.resource.data.points == resource.data.points + 1
                    );

      allow delete: if false;
    }
  }
}
