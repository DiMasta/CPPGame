rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Players collection — one document per signed-in user (keyed by their uid).
    match /players/{userId} {

      // Anyone signed in can read the leaderboard.
      allow read: if request.auth != null;

      // A user may only create / update their OWN document.
      // They may NOT set their own points from the client — points are 0 on
      // create, and only an admin / server (Cloud Function or console) can
      // award points later. This stops students from cheating their score.
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.points == 0;

      // Allow the user to update their own document, with their `points`
      // value either unchanged (nickname / profile edits) or increased by
      // between 1 and 5 (a correct quiz answer; the size of the award
      // depends on how many wrong guesses they made first — 5 / 3 / 2 / 1
      // for 0 / 1 / 2 / 3 wrong guesses respectively).
      //
      // POC compromise: this still trusts the client to compute the award
      // honestly. A determined cheater could write +5 from the JS console.
      // The proper hardening is a Cloud Function that grades answers
      // server-side and issues the points — that's the next anti-cheat step.
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.points >= resource.data.points
                    && request.resource.data.points <= resource.data.points + 5;

      allow delete: if false;
    }
  }
}
